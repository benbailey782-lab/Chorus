ANTHROPIC_API_KEY=sk-ant-...

# Voicebox (local TTS) — runs on the Mac where Voicebox is installed.
# On Windows dev without Voicebox, leave VOICEBOX_ENABLED=false.
# Voice metadata + reference-audio upload still work; TTS generation is disabled.
VOICEBOX_BASE_URL=http://localhost:5173
VOICEBOX_ENABLED=false

HOST=0.0.0.0
PORT=8080
DATA_DIR=./data
DB_PATH=./data/chorus.db
MDNS_NAME=chorus
LOG_LEVEL=INFO

CLAUDE_MODEL_OPUS=claude-opus-4-7
CLAUDE_MODEL_SONNET=claude-sonnet-4-6

# Max size for a single reference-audio upload (voice clone sample), in megabytes.
MAX_VOICE_SAMPLE_MB=25

# Phase 3 — file-drop LLM integration (§12A).
# Hard cap on the number of characters of book text substituted into
# extract_cast.md. Longer books are truncated to this limit (with a warning
# surfaced to the UI). 300k covers a ~50k-word single-book EPUB comfortably.
EXTRACT_CAST_CHAR_LIMIT=300000
